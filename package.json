{
  "name": "nitk-swimming-pool-app",
  "version": "1.0.0",
  "description": "NITK Swimming Pool Booking Application",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "start": "npm run start --prefix backend",
    "build": "npm run build --prefix frontend",
    "build-all": "npm run build --prefix frontend && npm run start --prefix backend",
    "setup": "node setup.js",
    "create-admin": "node create-admin.js",
    "seed": "node backend/seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
 "repository": {
  "type": "git",
  "url": "git+https://github.com/tarun11845/Campus-book.git"
 },
  "keywords": [
    "swimming",
    "pool",
    "booking",
    "nitk",
    "react",
    "nodejs"
  ],
